{
  "name": "very-good-adblock",
  "type": "module",
  "version": "0.1.0",
  "description": "A fast Manifest V3 ad blocker for Chrome and Firefox that removes ads, pop-ups, and YouTube and Twitch interruptions at the source. No telemetry.",
  "author": "Chris Breuer <chris@stacksjs.org>",
  "license": "MIT",
  "homepage": "https://github.com/chrisbbreuer/very-good-adblock#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chrisbbreuer/very-good-adblock.git"
  },
  "bugs": {
    "url": "https://github.com/chrisbbreuer/very-good-adblock/issues"
  },
  "keywords": [
    "adblock",
    "chrome-extension",
    "firefox-extension",
    "manifest-v3",
    "performant",
    "minimal",
    "modern",
    "popup-blocker",
    "youtube-adblock",
    "twitch-adblock",
    "twitch-video-ads",
    "stx",
    "bun"
  ],
  "scripts": {
    "build": "bun --bun scripts/build-extension.ts",
    "build:chrome": "bun --bun scripts/build-extension.ts --target=chrome",
    "build:firefox": "bun --bun scripts/build-extension.ts --target=firefox",
    "cache:youtube-fixture": "bun --bun scripts/cache-youtube-fixture.ts",
    "icons": "bun --bun scripts/generate-icons.ts",
    "docs:build": "bunpress build",
    "docs:dev": "bunpress dev",
    "docs:preview": "bunpress preview",
    "package": "bun run build && bun run validate:extension && bun --bun scripts/package-extension.ts",
    "package:firefox": "bun run build:firefox && bun run validate:extension:firefox && bun --bun scripts/package-extension.ts --target=firefox",
    "dev:firefox": "bun run build:firefox && web-ext run --source-dir=dist-firefox",
    "site:build": "bun run build && bun run docs:build && bun --bun scripts/build-site.ts",
    "screenshots": "bun run build && bun --bun scripts/store-screenshots.ts",
    "smoke:chrome": "bun run build && bun --bun scripts/smoke-extension.ts",
    "update:filters": "bun --bun scripts/update-filter-sources.ts",
    "validate:extension": "bun --bun scripts/validate-extension.ts",
    "validate:extension:firefox": "bun --bun scripts/validate-extension.ts --target=firefox",
    "validate:rules": "bun --bun scripts/validate-rules.ts",
    "test": "bun run cache:youtube-fixture && bun test ./test/*.test.ts",
    "lint": "bunx --bun pickier . --config .config/pickier.ts",
    "lint:fix": "bunx --bun pickier . --fix --config .config/pickier.ts",
    "typecheck": "bun --bun tsc --noEmit",
    "format": "bunx --bun pickier . --format --config .config/pickier.ts",
    "format:fix": "bunx --bun pickier . --format --write --config .config/pickier.ts",
    "fresh": "bunx rimraf node_modules/ bun.lock && bun i"
  },
  "dependencies": {
    "bun-plugin-stx": "^0.2.72"
  },
  "devDependencies": {
    "@stacksjs/bunpress": "^0.1.10",
    "@types/chrome": "^0.1.4",
    "better-dx": "^0.2.15",
    "typescript": "^5.9.3",
    "web-ext": "^10.4.0"
  },
  "git-hooks": {
    "pre-commit": {
      "staged-lint": {
        "*.{js,ts,json,yaml,yml,md}": "bunx --bun pickier lint --fix"
      },
      "autoRestage": true
    },
    "commit-msg": "bunx gitlint --edit .git/COMMIT_EDITMSG"
  }
}
