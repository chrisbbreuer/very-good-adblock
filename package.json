{
  "name": "very-good-adblock",
  "type": "module",
  "version": "0.2.2",
  "description": "A fast Manifest V3 ad blocker for Chrome, Firefox, and Safari that removes ads, pop-ups, and YouTube and Twitch interruptions at the source. No telemetry.",
  "author": "Chris Breuer <chris@stacksjs.org>",
  "license": "MIT",
  "homepage": "https://github.com/chrisbbreuer/very-good-adblock#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chrisbbreuer/very-good-adblock.git"
  },
  "bugs": {
    "url": "https://github.com/chrisbbreuer/very-good-adblock/issues"
  },
  "keywords": [
    "adblock",
    "chrome-extension",
    "firefox-extension",
    "safari-extension",
    "manifest-v3",
    "performant",
    "minimal",
    "modern",
    "popup-blocker",
    "youtube-adblock",
    "twitch-adblock",
    "twitch-video-ads",
    "stx",
    "bun"
  ],
  "scripts": {
    "build": "bun node_modules/@stacksjs/buddy/dist/cli.js extension:build --target chrome",
    "build:chrome": "bun node_modules/@stacksjs/buddy/dist/cli.js extension:build --target chrome",
    "build:firefox": "bun node_modules/@stacksjs/buddy/dist/cli.js extension:build --target firefox",
    "build:safari": "bun node_modules/@stacksjs/buddy/dist/cli.js extension:build --target safari",
    "cache:youtube-fixture": "bun --bun resources/scripts/cache-youtube-fixture.ts",
    "icons": "bun --bun resources/scripts/generate-icons.ts",
    "docs:build": "bunpress build",
    "docs:dev": "bunpress dev",
    "docs:preview": "bunpress preview",
    "package": "bun run build && bun run validate:extension && bun --bun resources/scripts/package-extension.ts",
    "package:firefox": "bun run build:firefox && bun run validate:extension:firefox && bun --bun resources/scripts/package-extension.ts --target=firefox",
    "package:safari": "bun run build:safari && bun run validate:extension:safari && bun --bun resources/scripts/package-extension.ts --target=safari",
    "chrome:publish": "bun node_modules/@stacksjs/buddy/dist/cli.js extension:chrome:publish",
    "chrome:status": "bun node_modules/@stacksjs/buddy/dist/cli.js extension:chrome:status",
    "firefox:publish": "bun node_modules/@stacksjs/buddy/dist/cli.js extension:firefox:publish",
    "safari:app": "bun node_modules/@stacksjs/buddy/dist/cli.js extension:safari:app",
    "safari:init": "bun node_modules/@stacksjs/buddy/dist/cli.js extension:safari:init",
    "safari:provision": "bun node_modules/@stacksjs/buddy/dist/cli.js extension:safari:provision",
    "safari:publish": "bun node_modules/@stacksjs/buddy/dist/cli.js extension:safari:publish",
    "safari:validate": "bun node_modules/@stacksjs/buddy/dist/cli.js extension:safari:publish --validate-only",
    "dev:firefox": "bun run build:firefox && web-ext run --source-dir=dist-firefox",
    "site:build": "bun run build && bun run docs:build && bun --bun resources/scripts/build-site.ts",
    "deploy": "bunx --bun buddy deploy",
    "dns:diff": "bun node_modules/@stacksjs/buddy/dist/cli.js dns:diff verygoodadblock.org",
    "dns:sync": "bun node_modules/@stacksjs/buddy/dist/cli.js dns:sync verygoodadblock.org",
    "dns:pull": "bun node_modules/@stacksjs/buddy/dist/cli.js dns:pull verygoodadblock.org",
    "release": "bun node_modules/@stacksjs/buddy/dist/cli.js release",
    "release:patch": "bun node_modules/@stacksjs/buddy/dist/cli.js release --bump patch",
    "release:minor": "bun node_modules/@stacksjs/buddy/dist/cli.js release --bump minor",
    "release:major": "bun node_modules/@stacksjs/buddy/dist/cli.js release --bump major",
    "changelog": "bunx --bun buddy changelog",
    "screenshots": "bun run build && bun --bun resources/scripts/store-screenshots.ts",
    "preview:marketing": "bun run build && bun --bun resources/scripts/generate-marketing-preview.ts",
    "smoke:chrome": "bun run build && bun --bun resources/scripts/smoke-extension.ts",
    "bench": "bun --bun bench/index.ts",
    "update:filters": "bun --bun resources/scripts/update-filter-sources.ts",
    "validate:extension": "bun --bun resources/scripts/validate-extension.ts",
    "validate:extension:firefox": "bun --bun resources/scripts/validate-extension.ts --target=firefox",
    "validate:extension:safari": "bun --bun resources/scripts/validate-extension.ts --target=safari",
    "validate:rules": "bun --bun resources/scripts/validate-rules.ts",
    "test": "bun run cache:youtube-fixture && bun test --parallel=1 ./test/*.test.ts",
    "lint": "bunx --bun pickier .",
    "lint:fix": "bunx --bun pickier . --fix",
    "typecheck": "bun --bun tsc --noEmit",
    "format": "bunx --bun pickier . --format",
    "format:fix": "bunx --bun pickier . --format --write",
    "fresh": "bunx rimraf node_modules/ bun.lock && bun i"
  },
  "dependencies": {
    "stacks": "^0.70.150"
  },
  "devDependencies": {
    "@ghostery/adblocker": "^2.18.1",
    "@gorhill/ubo-core": "^0.1.30",
    "@types/chrome": "^0.2.2",
    "adblockpluscore": "^0.11.1",
    "better-dx": "^0.2.19",
    "web-ext": "^10.4.0"
  },
  "git-hooks": {
    "pre-commit": {
      "staged-lint": {
        "*.{js,ts,json,yaml,yml,md}": "bunx --bun pickier lint --fix"
      },
      "autoRestage": true
    },
    "commit-msg": "bunx gitlint --edit .git/COMMIT_EDITMSG"
  }
}
