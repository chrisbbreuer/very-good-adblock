<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Very Good AdBlock</title>
    <link rel="stylesheet" href="/styles.css">
  </head>
  <body class="popup-shell">
    <main class="popup-frame" data-view="loading">
      <section class="popup-hero">
        <div>
          <p class="eyebrow">Very Good AdBlock</p>
          <h1 id="site-title">Protection active</h1>
        </div>
        <button id="protection-toggle" class="power-button" type="button" aria-label="Toggle protection" aria-pressed="true">
          <svg class="power-glyph" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true">
            <line x1="12" y1="3.6" x2="12" y2="11.4"></line>
            <path d="M6.3 7.2a7.4 7.4 0 1 0 11.4 0"></path>
          </svg>
        </button>
      </section>

      <div id="pause-row" class="pause-row" hidden>
        <span id="pause-label" class="muted">Pause protection</span>
        <div class="pause-buttons">
          <button class="chip-button" data-pause="15" type="button">15m</button>
          <button class="chip-button" data-pause="30" type="button">30m</button>
          <button class="chip-button" data-pause="60" type="button">1h</button>
          <button id="resume-btn" class="chip-button accent" type="button" hidden>Resume now</button>
        </div>
      </div>

      <section class="stat-grid" aria-label="Very Good AdBlock statistics">
        <article class="metric-card primary">
          <span>Blocked</span>
          <strong id="page-blocked">0</strong>
          <small id="page-breakdown">on this page</small>
        </article>
        <article class="metric-card">
          <span>Data saved</span>
          <strong id="data-saved">0 KB</strong>
          <small>estimated</small>
        </article>
        <article class="metric-card">
          <span>Video time</span>
          <strong id="video-time">0 min</strong>
          <small>estimated</small>
        </article>
      </section>

      <section class="timeline-card">
        <div class="section-heading">
          <span>Last 24 hours</span>
          <strong id="chart-peak">0 peak</strong>
        </div>
        <div id="hourly-chart" class="bar-chart" role="list" aria-label="Blocked ads by hour"></div>
        <div class="timeline-footer">
          <span>older</span>
          <strong id="lifetime-blocked">0 lifetime</strong>
          <span>now</span>
        </div>
      </section>

      <section class="site-card current-site-card">
        <div class="site-card-top">
          <div class="site-id">
            <img id="site-favicon" class="site-favicon" alt="" width="20" height="20" hidden>
            <div class="site-id-text">
              <span class="muted">Current site</span>
              <strong id="current-site">No active tab</strong>
            </div>
          </div>
          <button id="site-toggle" class="soft-button" type="button">Allow</button>
        </div>
        <span class="site-stat-caption">All time on this site</span>
        <div id="current-site-stats" class="site-stat-grid" aria-label="Current site statistics">
          <article>
            <span>Blocked here</span>
            <strong id="site-blocked">0</strong>
          </article>
          <article>
            <span>Data here</span>
            <strong id="site-data">0 KB</strong>
          </article>
          <article>
            <span>Video here</span>
            <strong id="site-video">0 min</strong>
          </article>
        </div>
        <p id="site-last-activity" class="site-footnote">No current-site events yet.</p>
      </section>

      <section class="category-list" aria-label="Top blocked sources">
        <div class="section-heading">
          <span>Top sources</span>
          <button id="open-options" class="icon-button" type="button" aria-label="Open dashboard">↗</button>
        </div>
        <div id="top-categories"></div>
      </section>

      <p id="status-message" class="status-message" role="status">Loading protection state...</p>
    </main>
    <script type="module" src="/popup.js"></script>
  </body>
</html>
